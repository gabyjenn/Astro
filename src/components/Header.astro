---
import Menu from './Menu.astro'
import Navigation from './Navigation.astro'
import ThemeIcon from './ThemeIcon.astro'
---
<style>
    a {
        padding: 0.5rem 1rem;
        color: white;
        background-color: #4c1d95;
        text-decoration: none;
    }
</style>

<header>
    <nav>
        <div>
            <ThemeIcon />
            <Menu />
        </div>
        <Navigation />
    </nav>
</header>

<style>
    div{
        display: flex;
        justify-content: space-between;
    }
</style>